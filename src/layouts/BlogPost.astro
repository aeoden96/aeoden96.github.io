---
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
type Props = CollectionEntry<"blog">["data"];

const { title, description, pubDate, updatedDate, heroImage } = Astro.props;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} />
  </head>

  <body class="bg-black text-white min-h-screen flex flex-col font-sans">
    <main class="w-full flex-grow max-w-6xl mx-auto px-6 md:px-10 lg:px-40 py-10 flex flex-col">
      <Header />
      <article>
        <div  class:list={[
    "prose prose-invert w-full max-w-none md:max-w-[720px] mx-auto",
    "prose-p:text-justify prose-img:rounded-none",
    
    // links
    "prose-a:text-white prose-a:font-medium prose-a:inline prose-a:underline",
    // links - hover
    "prose-a:transition-all prose-a:duration-300 prose-a:hover:text-gray-400",
    
    // headings - shared
    "prose-headings:font-bold prose-headings:tracking-tight prose-headings:uppercase",
    
    // h1
    "prose-h1:mt-0 prose-h1:mb-4 prose-h1:text-3xl",
    // h1 - responsive
    "sm:prose-h1:text-4xl",
    
    // h2
    "prose-h2:mt-10 prose-h2:mb-4 prose-h2:text-2xl",
    // h2 - responsive
    "sm:prose-h2:text-3xl",
    
    // h3
    "prose-h3:mt-8 prose-h3:mb-3 prose-h3:text-xl",
    // h3 - responsive
    "sm:prose-h3:text-2xl",
    
    // h4
    "prose-h4:mt-6 prose-h4:mb-2 prose-h4:text-lg",
    
    // p
    "prose-p:text-justify prose-p:leading-relaxed prose-p:text-base prose-p:text-gray-300",
    // p - responsive
    "sm:prose-p:text-lg",
    
    // blockquote
    "prose-blockquote:border-l-4 prose-blockquote:border-gray-600 prose-blockquote:pl-4 prose-blockquote:italic prose-blockquote:my-8 prose-blockquote:text-gray-400",
    
    // code
    "prose-code:before:content-none prose-code:after:content-none prose-code:font-mono prose-code:text-sm prose-code:px-1 prose-code:mx-0.5 prose-code:py-1 prose-code:rounded-none prose-code:bg-gray-900 prose-code:border prose-code:border-gray-800 prose-code:text-gray-300",
    
    // pre
    "prose-pre:p-6 prose-pre:my-8 prose-pre:rounded-none prose-pre:overflow-auto prose-pre:bg-gray-900 prose-pre:border prose-pre:border-gray-800 prose-pre:text-sm",
    
    // pre > code
    "[&_pre_code]:bg-transparent [&_pre_code]:p-0 [&_pre_code]:border-none [&_pre_code]:text-gray-300"
  ]}>
          <div class="mb-12 mt-4 text-left">
            <h1 class="text-4xl md:text-5xl font-bold uppercase tracking-tighter mb-4 text-white !leading-tight">{title}</h1>
            <div class="text-xs text-gray-500 uppercase tracking-widest mb-4 flex gap-4">
              <span><FormattedDate date={pubDate} /></span>
              {
                updatedDate && (
                  <span>
                    (UPDATED: <FormattedDate date={updatedDate} />)
                  </span>
                )
              }
            </div>
            <div class="w-full h-px bg-gray-800 my-8 flex-shrink-0"></div>
          </div>
          <slot />
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>

