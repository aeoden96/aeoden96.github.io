---
---

<canvas id="world-bg-canvas" transition:persist="world-bg"></canvas>

<style>
  #world-bg-canvas {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 0;
    pointer-events: none;
    display: block;
  }
</style>

<script>
  import worldBgShader from "../shaders/world_bg.ts";

  const VERTEX_SHADER = `
    attribute vec4 aVertexPosition;
    void main() { gl_Position = aVertexPosition; }
  `;

  function loadShader(gl: WebGLRenderingContext, type: number, source: string) {
    const shader = gl.createShader(type);
    if (!shader) return null;
    gl.shaderSource(shader, source);
    gl.compileShader(shader);
    if (!gl.getShaderParameter(shader, gl.COMPILE_STATUS)) {
      console.error("World-bg shader compile error:", gl.getShaderInfoLog(shader));
      gl.deleteShader(shader);
      return null;
    }
    return shader;
  }

  function initProgram(gl: WebGLRenderingContext, vs: string, fs: string) {
    const vert = loadShader(gl, gl.VERTEX_SHADER, vs);
    const frag = loadShader(gl, gl.FRAGMENT_SHADER, fs);
    if (!vert || !frag) return null;
    const program = gl.createProgram()!;
    gl.attachShader(program, vert);
    gl.attachShader(program, frag);
    gl.linkProgram(program);
    if (!gl.getProgramParameter(program, gl.LINK_STATUS)) {
      console.error("World-bg program link error:", gl.getProgramInfoLog(program));
      return null;
    }
    return program;
  }

  // The canvas is transition:persist'd, so it survives client-side navigations.
  // Initialise the WebGL context and render loop exactly once for the whole session.
  if (!(window as any).__worldBgInit) {
    (window as any).__worldBgInit = true;

  const canvas = document.getElementById("world-bg-canvas") as HTMLCanvasElement;
  const gl = canvas?.getContext("webgl");

  if (!gl) {
    if (canvas) canvas.style.display = "none";
  } else {
    const buf = gl.createBuffer();
    gl.bindBuffer(gl.ARRAY_BUFFER, buf);
    gl.bufferData(
      gl.ARRAY_BUFFER,
      new Float32Array([-1, -1, 1, -1, 1, 1, -1, 1]),
      gl.STATIC_DRAW
    );

    const program = initProgram(gl, VERTEX_SHADER, worldBgShader);
    if (program) {
      const aPos   = gl.getAttribLocation(program, "aVertexPosition");
      const uTime  = gl.getUniformLocation(program, "uTime");
      const uRes   = gl.getUniformLocation(program, "uResolution");
      const uShift = gl.getUniformLocation(program, "uShift");
      const uSteps = gl.getUniformLocation(program, "uSteps");
      const uBright = gl.getUniformLocation(program, "uBright");
      const startTime = Date.now();

      const mq = (q: string) => window.matchMedia(q).matches;
      const mobile = mq("(pointer: coarse)");

      // Glow brightness by context. On desktop the homepage hero is full and
      // fades down past the fold; on mobile we just hold the dim level the whole
      // way (content sits close over the graphic throughout). Inner pages are
      // dim everywhere. Recomputed on scroll + each navigation.
      const BRIGHT_TOP   = 1.0;   // homepage hero (desktop only)
      const BRIGHT_FOLD  = 0.3;   // homepage past the fold / mobile homepage
      const BRIGHT_OTHER = 0.3;   // every other page
      let brightness = BRIGHT_TOP;
      const isHome = () =>
        location.pathname === "/" || location.pathname === "/index.html";
      function updateBrightness() {
        if (!isHome()) {
          brightness = BRIGHT_OTHER;
        } else if (mobile) {
          brightness = BRIGHT_FOLD;            // static dim across the homepage
        } else {
          const f = Math.min(window.scrollY / (window.innerHeight * 0.8), 1);
          brightness = BRIGHT_TOP + (BRIGHT_FOLD - BRIGHT_TOP) * f;
        }
      }

      // ── Quality tier, picked once. Trades resolution / march steps / frame
      // rate to keep weak GPUs and phones smooth. The glow is soft, so a low
      // resScale (CSS-upscaled) is essentially invisible.
      const reduceMotion = mq("(prefers-reduced-motion: reduce)");
      const lowPower =
        mq("(pointer: coarse)") ||
        Math.min(window.innerWidth, window.innerHeight) < 740 ||
        (navigator.hardwareConcurrency || 4) <= 4;
      const quality = lowPower
        ? { resScale: 0.66, steps: 56, fps: 30 }
        : { resScale: 1.0, steps: 90, fps: 30 };
      const frameInterval = 1000 / quality.fps;

      // Camera offset, tweened from `from` -> `to` over a short duration with a
      // fast ease-in/ease-out, so each route change gently reorients the fractal.
      const DURATION = 650;                 // ms — keep it quick
      const cur  = { x: 0, y: 0 };
      const from = { x: 0, y: 0 };
      const to   = { x: 0, y: 0 };
      let tweenStart = -Infinity;

      const easeInOut = (t: number) =>
        t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;

      function relocate() {
        from.x = cur.x;
        from.y = cur.y;
        const angle = Math.random() * Math.PI * 2;
        const dist = 6 + Math.random() * 6;   // small reorientation per nav
        to.x += Math.cos(angle) * dist;
        to.y += Math.sin(angle) * dist;
        tweenStart = Date.now();
      }
      // Draw exactly one frame. `snap` jumps the tween straight to its target
      // (used by the reduced-motion path, which never animates).
      function draw(snap: boolean) {
        const e = snap ? 1 : easeInOut(Math.min((Date.now() - tweenStart) / DURATION, 1));
        cur.x = from.x + (to.x - from.x) * e;
        cur.y = from.y + (to.y - from.y) * e;

        // Render below native and let CSS upscale — cheap, and invisible on a
        // soft glow that already dithers its own banding.
        const w = Math.round(canvas.clientWidth * quality.resScale);
        const h = Math.round(canvas.clientHeight * quality.resScale);
        if (canvas.width !== w || canvas.height !== h) {
          canvas.width = w;
          canvas.height = h;
          gl!.viewport(0, 0, w, h);
        }

        gl!.clearColor(0.039, 0.051, 0.078, 1.0);
        gl!.clear(gl!.COLOR_BUFFER_BIT);

        gl!.bindBuffer(gl!.ARRAY_BUFFER, buf);
        gl!.vertexAttribPointer(aPos, 2, gl!.FLOAT, false, 0, 0);
        gl!.enableVertexAttribArray(aPos);
        gl!.useProgram(program);

        gl!.uniform1f(uTime, (Date.now() - startTime) / 1000);
        gl!.uniform2f(uRes, canvas.width, canvas.height);
        gl!.uniform2f(uShift, cur.x, cur.y);
        gl!.uniform1f(uSteps, quality.steps);
        gl!.uniform1f(uBright, brightness);

        gl!.drawArrays(gl!.TRIANGLE_FAN, 0, 4);
      }

      // Individual blog posts / notes turn the graphic OFF. The canvas stays
      // (it's transition:persist'd, so we must never destroy it), but we stop
      // the loop and clear it to the page navy — the dot grid + amber edge glow
      // carry the background there instead.
      const graphicOff = () =>
        /^\/(blog|notes|projects|experiments)\/[^/]+/.test(location.pathname);

      function clearToNavy() {
        const w = Math.round(canvas.clientWidth * quality.resScale);
        const h = Math.round(canvas.clientHeight * quality.resScale);
        if (canvas.width !== w || canvas.height !== h) {
          canvas.width = w;
          canvas.height = h;
        }
        gl!.viewport(0, 0, canvas.width, canvas.height);
        gl!.clearColor(0.039, 0.051, 0.078, 1.0);
        gl!.clear(gl!.COLOR_BUFFER_BIT);
      }

      let rafId = 0;
      let last = 0;
      let looping = false;
      let redrawPending = false;

      const frame = (now: number) => {
        if (!looping) return;
        rafId = requestAnimationFrame(frame);
        if (now - last < frameInterval) return;   // throttle to quality.fps
        last = now;
        draw(false);
      };
      function startLoop() {
        if (looping) return;
        looping = true;
        last = 0;
        rafId = requestAnimationFrame(frame);
      }
      function stopLoop() {
        looping = false;
        cancelAnimationFrame(rafId);
      }

      // Decide what the background should do for the current route.
      function applyRoute() {
        updateBrightness();
        if (graphicOff()) {
          stopLoop();
          clearToNavy();
        } else if (reduceMotion) {
          stopLoop();
          draw(true);            // one static frame, no loop
        } else {
          startLoop();
        }
      }

      // Homepage brightness also tracks scroll; the static path needs a redraw.
      window.addEventListener("scroll", () => {
        updateBrightness();
        if (reduceMotion && !graphicOff() && !redrawPending) {
          redrawPending = true;
          requestAnimationFrame(() => { redrawPending = false; draw(true); });
        }
      }, { passive: true });

      // Pause while the tab is hidden; re-evaluate the route when it returns.
      document.addEventListener("visibilitychange", () => {
        if (document.hidden) stopLoop();
        else applyRoute();
      });

      // Each client-side navigation: reorient, then apply the new route.
      document.addEventListener("astro:after-swap", () => { relocate(); applyRoute(); });

      applyRoute();
    }
  }
  }
</script>
