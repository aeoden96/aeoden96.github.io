---
import HeaderLink from "./HeaderLink.astro";
import { toCanonicalUrl } from "../helpers";

const pathname =  toCanonicalUrl(Astro.url.pathname);
const subpath = pathname.match(/[^\/]+/g);
const currentPath = subpath?.[0] || "";
---

<header class="w-full py-8 mb-10 border-b border-gray-800">
  <div class="flex flex-row items-center justify-between gap-4">
    <div class="flex flex-row gap-6 flex-wrap">
      <a
        href="/"
        class={`text-sm md:text-base ${currentPath === "" ? "text-white" : "text-gray-500"} hover:text-white transition-colors uppercase`}
      >// HOME</a>
      <a
        href="/blog"
        class={`text-sm md:text-base ${currentPath === "blog" ? "text-white" : "text-gray-500"} hover:text-white transition-colors uppercase`}
      >// BLOGS</a>
      <a
        href="/experiments"
        class={`text-sm md:text-base ${currentPath === "experiments" ? "text-white" : "text-gray-500"} hover:text-white transition-colors uppercase`}
      >// EXPERIMENTS</a>
      <a
        href="/projects"
        class={`text-sm md:text-base ${currentPath === "projects" ? "text-white" : "text-gray-500"} hover:text-white transition-colors uppercase`}
      >// PROJECTS</a>
    </div>
  </div>
</header>
