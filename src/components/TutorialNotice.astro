---
export interface Props {
  originalUrl: string;
  originalTitle?: string;
  originalAuthor?: string;
  originalAuthorUrl?: string;
}

const { originalUrl, originalTitle = "the original blog", originalAuthor, originalAuthorUrl } = Astro.props;
---

<div class="my-8 p-6 border border-gray-800 bg-black">
  <div class="flex items-start gap-4">
    <div class="flex-shrink-0 mt-1">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        class="h-5 w-5 text-gray-500"
        viewBox="0 0 20 20"
        fill="currentColor"
      >
        <path
          fill-rule="evenodd"
          d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-7-4a1 1 0 11-2 0 1 1 0 012 0zM9 9a1 1 0 000 2v3a1 1 0 001 1h1a1 1 0 100-2h-1V9z"
          clip-rule="evenodd"></path>
      </svg>
    </div>
    <div>
      <h3 class="text-sm font-bold uppercase tracking-widest text-white mb-2 !mt-0">
        Based on a tutorial
      </h3>
      <div class="text-sm text-gray-400 leading-relaxed">
        <span class="block mb-2">
          For the original video or blog post, please visit:
          <a
            href={originalUrl}
            class="text-white hover:text-gray-300 underline underline-offset-4 transition-colors uppercase tracking-wider text-xs ml-1 font-bold"
            target="_blank"
            rel="noopener noreferrer"
          >{originalTitle}</a>
        </span>  
        {originalAuthor && (
          <span class="block">
            You can also find more cool stuff on the author's blog:
            <a href={originalAuthorUrl} class="text-white hover:text-gray-300 underline underline-offset-4 transition-colors uppercase tracking-wider text-xs ml-1 font-bold" target="_blank" rel="noopener noreferrer">
              {originalAuthor}
            </a>
          </span>
        )}
      </div>
    </div>
  </div>
</div>
