---
import BaseHead from "../../components/BaseHead.astro";
import Header from "../../components/Header.astro";
import FormattedDate from "../../components/FormattedDate.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../../consts";
import { getCollection } from "astro:content";

const notes = (await getCollection("notes")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

const allTags = [...new Set(
  notes.flatMap((n) => (n.data.tags ?? []).filter(t => t !== "snippet"))
)].sort();
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="bg-[#0a0d14] text-[#e8eaed] min-h-screen flex flex-col font-sans grid-bg">
    <main class="w-full flex-grow max-w-6xl mx-auto px-6 md:px-10 lg:px-16 flex flex-col">
      <Header />

      <section class="mt-16 mb-12">
        <h1 class="font-bold leading-tight">
          <span class="text-4xl md:text-[8rem] text-white block uppercase tracking-tighter">NOTES</span>
        </h1>
        <p class="text-[#9aa4b2] max-w-2xl mt-4 text-sm">Quick references, snippets, and short-form writing.</p>
      </section>

      <div class="flex flex-col sm:flex-row gap-3 mb-4">
        <div class="relative flex-1">
          <input
            id="notes-search"
            type="text"
            placeholder="Search notes..."
            autocomplete="off"
            class="w-full bg-[#10141d] border border-[#1c2230] text-[#e8eaed] placeholder-[#3a4454] font-mono text-sm px-4 py-2.5 rounded focus:outline-none focus:border-[#f59e0b] transition-colors duration-200"
          />
          <span class="absolute right-3 top-1/2 -translate-y-1/2 font-mono text-[10px] text-[#3a4454] pointer-events-none">/</span>
        </div>
      </div>

      {allTags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-4">
          {allTags.map((tag) => (
            <button
              class="tag-btn font-mono text-[10px] uppercase px-2.5 py-1 rounded border border-[#2a3344] text-[#9aa4b2] hover:border-[#f59e0b] hover:text-[#f59e0b] transition-colors duration-150"
              data-tag={tag}
            >
              #{tag}
            </button>
          ))}
        </div>
      )}

      <div class="flex items-center gap-2 mb-3">
        <span id="notes-count" class="font-mono text-xs text-[#5b6577]">{notes.length} entries</span>
      </div>

      <ul id="notes-list" class="divide-y divide-[#1c2230] border border-[#1c2230] rounded mb-20">
        {notes.map((note) => (
          <li
            class="note-item"
            data-title={note.data.title.toLowerCase()}
            data-tags={(note.data.tags ?? []).filter(t => t !== "snippet").join(" ").toLowerCase()}
            data-description={(note.data.description ?? "").toLowerCase()}
          >
            <a
              href={`/notes/${note.id}`}
              class="group flex items-center justify-between gap-4 px-4 py-3 hover:bg-[#10141d] transition-colors duration-150"
            >
              <div class="flex items-center gap-3 min-w-0">
                <span class="text-[#f59e0b] font-mono text-xs shrink-0">›</span>
                <span class="text-[#e8eaed] text-sm font-medium group-hover:text-white transition-colors truncate">
                  {note.data.title}
                </span>
              </div>
              <div class="flex items-center gap-3 shrink-0">
                {note.data.tags && note.data.tags.filter(t => t !== "snippet").length > 0 && (
                  <div class="hidden sm:flex gap-1.5">
                    {note.data.tags.filter(t => t !== "snippet").map((tag) => (
                      <span class="font-mono text-[9px] text-[#5b6577] uppercase border border-[#1c2230] px-1.5 py-0.5 rounded">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
                <span class="font-mono text-[10px] text-[#3a4454] whitespace-nowrap">
                  <FormattedDate date={note.data.pubDate} />
                </span>
              </div>
            </a>
          </li>
        ))}
      </ul>

      <p id="notes-empty" class="hidden font-mono text-sm text-[#3a4454] text-center py-8">
        No notes match your search.
      </p>
    </main>

    <footer class="max-w-6xl mx-auto w-full px-6 md:px-10 lg:px-16 py-8 border-t border-[#1c2230] flex flex-col md:flex-row items-start md:items-center justify-between gap-2 font-mono text-[11px] text-[#5b6577]">
      <p>Mateo Martinjak · Zagreb, HR</p>
      <p>© {new Date().getFullYear()} mteo.dev</p>
    </footer>
  </body>
</html>

<script>
  const input = document.getElementById("notes-search") as HTMLInputElement;
  const items = document.querySelectorAll<HTMLElement>(".note-item");
  const countEl = document.getElementById("notes-count");
  const emptyEl = document.getElementById("notes-empty");
  const tagBtns = document.querySelectorAll<HTMLElement>(".tag-btn");
  const total = items.length;

  let activeTag = "";

  function applyFilters() {
    const q = input.value.toLowerCase().trim();
    let visible = 0;

    items.forEach((item) => {
      const tags = item.dataset.tags ?? "";
      const haystack = [item.dataset.title ?? "", tags, item.dataset.description ?? ""].join(" ");
      const matchesSearch = !q || haystack.includes(q);
      const matchesTag = !activeTag || tags.split(" ").includes(activeTag);

      const match = matchesSearch && matchesTag;
      item.style.display = match ? "" : "none";
      if (match) visible++;
    });

    if (countEl) {
      countEl.textContent = q || activeTag
        ? `${visible} / ${total} entries`
        : `${total} entries`;
    }
    if (emptyEl) {
      emptyEl.classList.toggle("hidden", visible > 0);
    }
  }

  input?.addEventListener("input", applyFilters);

  tagBtns.forEach((btn) => {
    btn.addEventListener("click", () => {
      const tag = btn.dataset.tag ?? "";
      if (activeTag === tag) {
        activeTag = "";
        btn.classList.remove("border-[#f59e0b]", "text-[#f59e0b]");
        btn.classList.add("border-[#2a3344]", "text-[#9aa4b2]");
      } else {
        tagBtns.forEach((b) => {
          b.classList.remove("border-[#f59e0b]", "text-[#f59e0b]");
          b.classList.add("border-[#2a3344]", "text-[#9aa4b2]");
        });
        activeTag = tag;
        btn.classList.add("border-[#f59e0b]", "text-[#f59e0b]");
        btn.classList.remove("border-[#2a3344]", "text-[#9aa4b2]");
      }
      applyFilters();
    });
  });

  document.addEventListener("keydown", (e) => {
    if (e.key === "/" && document.activeElement !== input) {
      e.preventDefault();
      input?.focus();
    }
    if (e.key === "Escape") {
      input?.blur();
    }
  });
</script>
