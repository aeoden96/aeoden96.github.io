---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import FormattedDate from "../components/FormattedDate.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../consts";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 2);

const projects = (await getCollection("projects")).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
).slice(0, 2);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body class="min-h-screen w-full bg-[#0a0d14] text-[#e8eaed] font-sans grid-bg">
    <div class="max-w-6xl mx-auto px-6 md:px-10 lg:px-16">
      <Header />

      <!-- Hero -->
      <section class="py-20 md:py-28">
        <p class="font-mono accent-text text-lg mb-4">&gt;<span class="cursor-blink">_</span></p>
        <h1 class="font-bold leading-[0.95] tracking-tight">
          <span class="text-[clamp(2.5rem,9vw,7rem)] text-white block">SOFTWARE</span>
          <span class="text-[clamp(2.5rem,9vw,7rem)] accent-text block">ENGINEER</span>
        </h1>
        <p class="font-mono text-sm text-[#9aa4b2] mt-5 tracking-wide">
          // frontend background · backend systems · moving into data engineering
        </p>

        <p class="font-mono text-sm text-[#9aa4b2] mt-6 max-w-xl leading-relaxed">
          <span id="whoami-cmd" class="text-emerald-400"></span>
          <br />
          <span id="whoami-output" style="opacity:0">
            I've built frontends people actually use (React, Next.js — including
            a transit app with 4k+ active users). Now focused on the backend and
            data layer: Python, pipelines, large-scale storage. Moving
            deliberately toward data engineering.
          </span>
        </p>

        <div class="flex flex-wrap gap-3 mt-8">
          <a href="/blog" class="font-mono text-xs uppercase tracking-widest border accent-border accent-text px-4 py-2 rounded hover-accent-bg transition-colors">
            Read the blog →
          </a>
          <a href="/projects" class="font-mono text-xs uppercase tracking-widest border border-[#2a3344] text-[#9aa4b2] px-4 py-2 rounded hover-accent-border hover-accent-text transition-colors">
            View projects →
          </a>
          <a href="https://github.com/aeoden96" target="_blank" class="font-mono text-xs uppercase tracking-widest border border-[#2a3344] text-[#9aa4b2] px-4 py-2 rounded hover-accent-border hover-accent-text transition-colors">
            GitHub
          </a>
          <a href="https://www.linkedin.com/in/mateo-martinjak-803040197/" target="_blank" class="font-mono text-xs uppercase tracking-widest border border-[#2a3344] text-[#9aa4b2] px-4 py-2 rounded hover-accent-border hover-accent-text transition-colors">
            LinkedIn
          </a>
        </div>
      </section>

      <!-- Recent logs -->
      {posts.length > 0 && (
        <section class="py-16 border-t border-[#1c2230] fade-up">
          <div class="flex items-baseline justify-between mb-8">
            <h2 class="font-mono text-sm uppercase tracking-[0.3em] text-[#9aa4b2]">
              <span class="accent-text">#</span> recent_blogs
            </h2>
            <a href="/blog" class="font-mono text-xs uppercase tracking-widest accent-text hover:text-white transition-colors">
              All posts →
            </a>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {posts.map((post, i) => (
              <a
                href={`/blog/${post.id}`}
                class="group block rounded-lg border border-[#1c2230] bg-[#10141d] hover-accent-border transition-colors p-6 fade-up"
                style={`transition-delay: ${i * 80}ms`}
              >
                <div class="flex items-center gap-2 font-mono text-xs mb-3">
                  <span class="text-[#5b6577]">[</span>
                  <span class="accent-text-dim"><FormattedDate date={post.data.pubDate} /></span>
                  <span class="text-[#5b6577]">]</span>
                </div>
                <h3 class="text-xl font-bold text-white mb-2">
                  {post.data.title}
                </h3>
                <p class="text-sm text-[#9aa4b2] leading-relaxed mb-4">
                  {post.data.description}
                </p>
                {post.data.tags && (
                  <div class="flex flex-wrap gap-2 mb-4">
                    {post.data.tags.map((tag) => (
                      <span class="font-mono text-[10px] uppercase text-[#9aa4b2] border border-[#2a3344] rounded px-2 py-1">
                        #{tag}
                      </span>
                    ))}
                  </div>
                )}
                <div class="border-t border-[#1c2230] pt-3 font-mono text-xs uppercase tracking-widest accent-text">
                  Read →
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Featured projects -->
      {projects.length > 0 && (
        <section class="py-16 border-t border-[#1c2230] fade-up">
          <div class="flex items-baseline justify-between mb-8">
            <h2 class="font-mono text-sm uppercase tracking-[0.3em] text-[#9aa4b2]">
              <span class="accent-text">#</span> projects
            </h2>
            <a href="/projects" class="font-mono text-xs uppercase tracking-widest accent-text hover:text-white transition-colors">
              All projects →
            </a>
          </div>

          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            {projects.map((project, i) => (
              <a
                href={`/projects/${project.id}`}
                class="group block rounded-lg border border-[#1c2230] bg-[#10141d] hover-accent-border transition-colors p-6 fade-up"
                style={`transition-delay: ${i * 80}ms`}
              >
                <h3 class="text-xl font-bold text-white mb-2">
                  {project.data.title}
                </h3>
                <p class="text-sm text-[#9aa4b2] leading-relaxed">
                  {project.data.description}
                </p>
                <div class="border-t border-[#1c2230] mt-4 pt-3 font-mono text-xs uppercase tracking-widest accent-text">
                  Open →
                </div>
              </a>
            ))}
          </div>
        </section>
      )}

      <!-- Ready to collaborate -->
      <section class="py-16 border-t border-[#1c2230] fade-up">
        <h2 class="font-mono text-lg text-white mb-3">
          &lt;<span class="accent-text">READY_TO_COLLABORATE</span> /&gt;
        </h2>
        <p class="text-sm text-[#9aa4b2] max-w-2xl leading-relaxed">
          Available for contract work in
          <span class="accent-text-dim"> backend systems</span>,
          <span class="accent-text-dim"> data pipelines</span>, and
          <span class="accent-text-dim"> data platform design</span>
          — including security-adjacent contexts. If you're moving, storing,
          or making sense of data at scale — let's talk.
        </p>
      </section>

      <!-- Footer -->
      <footer class="py-8 border-t border-[#1c2230] flex flex-col md:flex-row items-start md:items-center justify-between gap-2 font-mono text-[11px] text-[#5b6577]">
        <p>Mateo Martinjak · Zagreb, HR</p>
        <p>© {new Date().getFullYear()} mteo.dev</p>
      </footer>
    </div>
    <script>
      // Typewriter: "$ whoami" then reveal bio
      const CMD = '$ whoami';
      const cmdEl = document.getElementById('whoami-cmd');
      const outputEl = document.getElementById('whoami-output');
      let i = 0;
      setTimeout(() => {
        const timer = setInterval(() => {
          if (cmdEl) cmdEl.textContent = CMD.slice(0, ++i);
          if (i === CMD.length) {
            clearInterval(timer);
            if (outputEl) {
              outputEl.style.transition = 'opacity 0.4s ease';
              outputEl.style.opacity = '1';
            }
          }
        }, 55);
      }, 400);

      // Scroll fade-up via IntersectionObserver
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(e => {
          if (e.isIntersecting) {
            e.target.classList.add('is-visible');
            observer.unobserve(e.target);
          }
        });
      }, { threshold: 0.1 });

      document.querySelectorAll('.fade-up').forEach(el => observer.observe(el));
    </script>
  </body>
</html>
